{
  "name": "mule2logic-cli",
  "version": "0.1.0",
  "description": "CLI for MuleSoft to Logic Apps Standard migration",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "mule2logic": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint --fix src/ tests/",
    "format": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:fix": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "mulesoft",
    "logic-apps",
    "azure",
    "migration"
  ],
  "license": "MIT",
  "dependencies": {
    "@azure/monitor-opentelemetry": "^1.16.0",
    "@m2la/contracts": "file:../../packages/contracts/typescript",
    "@opentelemetry/api": "^1.9.1",
    "@types/archiver": "^7.0.0",
    "archiver": "^7.0.1",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "fast-xml-parser": "^5.5.12",
    "ora": "^9.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "eslint": "^10.2.0",
    "prettier": "^3.8.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1",
    "vitest": "^4.1.4"
  }
}
