{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.42.1.51946",
      "templateHash": "11765135406250885767"
    }
  },
  "parameters": {
    "environmentName": {
      "type": "string",
      "metadata": {
        "description": "Environment name used for resource naming."
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Azure region for the resources."
      }
    },
    "tags": {
      "type": "object",
      "defaultValue": {},
      "metadata": {
        "description": "Resource tags."
      }
    },
    "uamiPrincipalId": {
      "type": "string",
      "metadata": {
        "description": "Principal ID of the UAMI to grant Cognitive Services OpenAI User role."
      }
    },
    "uamiResourceId": {
      "type": "string",
      "metadata": {
        "description": "Resource ID of the UAMI to attach to the AI Services account."
      }
    },
    "logAnalyticsWorkspaceResourceId": {
      "type": "string",
      "metadata": {
        "description": "Resource ID of the Log Analytics workspace for diagnostic settings."
      }
    },
    "aiModelDeployments": {
      "type": "array",
      "defaultValue": [
        {
          "name": "gpt-4o",
          "model": {
            "format": "OpenAI",
            "name": "gpt-4o",
            "version": "2024-11-20"
          },
          "sku": {
            "name": "GlobalStandard",
            "capacity": 50
          }
        }
      ],
      "metadata": {
        "description": "OpenAI model deployments to provision."
      }
    }
  },
  "variables": {
    "aiServicesName": "[format('ais-m2la-{0}', parameters('environmentName'))]",
    "projectName": "[format('proj-m2la-{0}', parameters('environmentName'))]"
  },
  "resources": [
    {
      "type": "Microsoft.CognitiveServices/accounts",
      "apiVersion": "2025-06-01",
      "name": "[variables('aiServicesName')]",
      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]",
      "kind": "AIServices",
      "sku": {
        "name": "S0"
      },
      "identity": {
        "type": "UserAssigned",
        "userAssignedIdentities": {
          "[format('{0}', parameters('uamiResourceId'))]": {}
        }
      },
      "properties": {
        "allowProjectManagement": true,
        "customSubDomainName": "[format('ais-m2la-{0}-{1}', parameters('environmentName'), uniqueString(resourceGroup().id))]",
        "disableLocalAuth": true,
        "publicNetworkAccess": "Enabled"
      }
    },
    {
      "type": "Microsoft.CognitiveServices/accounts/projects",
      "apiVersion": "2025-06-01",
      "name": "[format('{0}/{1}', variables('aiServicesName'), variables('projectName'))]",
      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]",
      "identity": {
        "type": "UserAssigned",
        "userAssignedIdentities": {
          "[format('{0}', parameters('uamiResourceId'))]": {}
        }
      },
      "properties": {
        "displayName": "[format('MuleSoft to Logic Apps - {0}', parameters('environmentName'))]",
        "description": "AI Foundry project for the MuleSoft to Logic Apps migration platform."
      },
      "dependsOn": [
        "[resourceId('Microsoft.CognitiveServices/accounts', variables('aiServicesName'))]"
      ]
    },
    {
      "copy": {
        "name": "modelDeployments",
        "count": "[length(parameters('aiModelDeployments'))]",
        "mode": "serial",
        "batchSize": 1
      },
      "type": "Microsoft.CognitiveServices/accounts/deployments",
      "apiVersion": "2025-06-01",
      "name": "[format('{0}/{1}', variables('aiServicesName'), parameters('aiModelDeployments')[copyIndex()].name)]",
      "sku": "[parameters('aiModelDeployments')[copyIndex()].sku]",
      "properties": {
        "model": "[parameters('aiModelDeployments')[copyIndex()].model]"
      },
      "dependsOn": [
        "[resourceId('Microsoft.CognitiveServices/accounts', variables('aiServicesName'))]"
      ]
    },
    {
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "scope": "[resourceId('Microsoft.CognitiveServices/accounts', variables('aiServicesName'))]",
      "name": "[guid(resourceId('Microsoft.CognitiveServices/accounts', variables('aiServicesName')), parameters('uamiPrincipalId'), '5e0bd9bd-7b93-4f28-af87-19fc36ad61bd')]",
      "properties": {
        "principalId": "[parameters('uamiPrincipalId')]",
        "roleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', '5e0bd9bd-7b93-4f28-af87-19fc36ad61bd')]",
        "principalType": "ServicePrincipal"
      },
      "dependsOn": [
        "[resourceId('Microsoft.CognitiveServices/accounts', variables('aiServicesName'))]"
      ]
    },
    {
      "type": "Microsoft.Insights/diagnosticSettings",
      "apiVersion": "2021-05-01-preview",
      "scope": "[resourceId('Microsoft.CognitiveServices/accounts', variables('aiServicesName'))]",
      "name": "allLogsAndMetrics",
      "properties": {
        "workspaceId": "[parameters('logAnalyticsWorkspaceResourceId')]",
        "logs": [
          {
            "categoryGroup": "allLogs",
            "enabled": true
          }
        ],
        "metrics": [
          {
            "category": "AllMetrics",
            "enabled": true
          }
        ]
      },
      "dependsOn": [
        "[resourceId('Microsoft.CognitiveServices/accounts', variables('aiServicesName'))]"
      ]
    }
  ],
  "outputs": {
    "projectName": {
      "type": "string",
      "metadata": {
        "description": "Name of the AI Foundry project."
      },
      "value": "[variables('projectName')]"
    },
    "aiServicesName": {
      "type": "string",
      "metadata": {
        "description": "Name of the AI Services account."
      },
      "value": "[variables('aiServicesName')]"
    },
    "aiServicesEndpoint": {
      "type": "string",
      "metadata": {
        "description": "AI Services account endpoint."
      },
      "value": "[reference(resourceId('Microsoft.CognitiveServices/accounts', variables('aiServicesName')), '2025-06-01').endpoint]"
    }
  }
}