{
  "definition": {
    "$schema": "https://schema.management.azure.com/providers/Microsoft.Logic/schemas/2016-06-01/workflowdefinition.json#",
    "actions": {
      "error_handler_on_error_continue_1": {
        "actions": {
          "set_payload_0": {
            "inputs": {
              "payload": "An error occurred"
            },
            "runAfter": {},
            "type": "Compose"
          }
        },
        "description": "Error handler for type 'ANY' (on_error_continue) \u2014 continues execution (errors are suppressed)",
        "runAfter": {
          "http_request_request_3": [
            "Failed",
            "TimedOut"
          ]
        },
        "type": "Scope"
      },
      "error_handler_on_error_propagate_0": {
        "actions": {
          "set_payload_0": {
            "inputs": {
              "payload": "Connection error occurred"
            },
            "runAfter": {},
            "type": "Compose"
          }
        },
        "description": "Error handler for type 'HTTP:CONNECTIVITY' (on_error_propagate)",
        "runAfter": {
          "http_request_request_3": [
            "Failed",
            "TimedOut"
          ]
        },
        "type": "Scope"
      },
      "flow_ref_2": {
        "actions": {
          "set_payload_1": {
            "inputs": {
              "payload": "Processed by shared logic"
            },
            "runAfter": {
              "set_variable_status_0": [
                "Succeeded"
              ]
            },
            "type": "Compose"
          },
          "set_variable_status_0": {
            "inputs": {
              "variables": [
                {
                  "name": "status",
                  "type": "String",
                  "value": "processed"
                }
              ]
            },
            "runAfter": {},
            "type": "InitializeVariable"
          }
        },
        "description": "Inlined sub-flow 'sharedLogic'",
        "runAfter": {
          "transform_1": [
            "Succeeded"
          ]
        },
        "type": "Scope"
      },
      "http_request_request_3": {
        "inputs": {
          "method": "POST",
          "uri": "https://example.com/api"
        },
        "runAfter": {
          "flow_ref_2": [
            "Succeeded"
          ]
        },
        "type": "Http"
      },
      "set_variable_greeting_0": {
        "inputs": {
          "variables": [
            {
              "name": "greeting",
              "type": "String",
              "value": "${greeting.message}"
            }
          ]
        },
        "runAfter": {},
        "type": "InitializeVariable"
      },
      "transform_1": {
        "inputs": {
          "expression": "%dw 2.0\noutput application/json\n---\n{\n    message: vars.greeting,\n    timestamp: now()\n}"
        },
        "runAfter": {
          "set_variable_greeting_0": [
            "Succeeded"
          ]
        },
        "type": "Compose"
      }
    },
    "contentVersion": "1.0.0.0",
    "outputs": {},
    "triggers": {
      "manual": {
        "inputs": {
          "method": "GET",
          "schema": {}
        },
        "kind": "Http",
        "operationOptions": "EnableSchemaValidation",
        "type": "Request"
      }
    }
  },
  "kind": "Stateful"
}
