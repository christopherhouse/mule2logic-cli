{
  "$defs": {
    "ArtifactEntry": {
      "description": "A single output artifact in the generated Logic Apps project.",
      "properties": {
        "path": {
          "description": "Relative path of the artifact in the output directory",
          "title": "Path",
          "type": "string"
        },
        "artifact_type": {
          "description": "Type of artifact (e.g., 'workflow', 'host_json', 'connections_json', 'parameters_json')",
          "title": "Artifact Type",
          "type": "string"
        },
        "size_bytes": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "File size in bytes, if known",
          "title": "Size Bytes"
        }
      },
      "required": [
        "path",
        "artifact_type"
      ],
      "title": "ArtifactEntry",
      "type": "object"
    },
    "ArtifactManifest": {
      "description": "Manifest of all generated output artifacts.",
      "properties": {
        "artifacts": {
          "description": "List of generated artifacts",
          "items": {
            "$ref": "#/$defs/ArtifactEntry"
          },
          "title": "Artifacts",
          "type": "array"
        },
        "output_directory": {
          "description": "Root output directory path",
          "title": "Output Directory",
          "type": "string"
        },
        "mode": {
          "$ref": "#/$defs/InputMode",
          "description": "Input mode that produced these artifacts"
        }
      },
      "required": [
        "output_directory",
        "mode"
      ],
      "title": "ArtifactManifest",
      "type": "object"
    },
    "ConstructCount": {
      "description": "Summary counts of supported, unsupported, and partially supported constructs.",
      "properties": {
        "supported": {
          "default": 0,
          "description": "Number of fully supported constructs",
          "minimum": 0,
          "title": "Supported",
          "type": "integer"
        },
        "unsupported": {
          "default": 0,
          "description": "Number of unsupported constructs",
          "minimum": 0,
          "title": "Unsupported",
          "type": "integer"
        },
        "partial": {
          "default": 0,
          "description": "Number of partially supported constructs",
          "minimum": 0,
          "title": "Partial",
          "type": "integer"
        },
        "details": {
          "additionalProperties": {
            "type": "integer"
          },
          "description": "Per-construct-type counts (e.g., {'http_listener': 2})",
          "title": "Details",
          "type": "object"
        }
      },
      "title": "ConstructCount",
      "type": "object"
    },
    "GapCategory": {
      "description": "Categories for migration gaps.",
      "enum": [
        "unsupported_construct",
        "unresolvable_reference",
        "partial_support",
        "connector_mismatch",
        "dataweave_complexity"
      ],
      "title": "GapCategory",
      "type": "string"
    },
    "InputMode": {
      "description": "Discriminator for project vs single-flow input mode.",
      "enum": [
        "project",
        "single_flow"
      ],
      "title": "InputMode",
      "type": "string"
    },
    "MigrationGap": {
      "description": "A construct or reference that cannot be fully migrated.",
      "properties": {
        "construct_name": {
          "description": "Name of the MuleSoft construct",
          "title": "Construct Name",
          "type": "string"
        },
        "source_location": {
          "description": "Source file and line (e.g., 'flows/main.xml:42')",
          "title": "Source Location",
          "type": "string"
        },
        "category": {
          "$ref": "#/$defs/GapCategory",
          "description": "Classification of the gap"
        },
        "severity": {
          "$ref": "#/$defs/Severity",
          "description": "Impact severity"
        },
        "message": {
          "description": "Human-readable description of the gap",
          "title": "Message",
          "type": "string"
        },
        "suggested_workaround": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Optional workaround suggestion",
          "title": "Suggested Workaround"
        }
      },
      "required": [
        "construct_name",
        "source_location",
        "category",
        "severity",
        "message"
      ],
      "title": "MigrationGap",
      "type": "object"
    },
    "Severity": {
      "description": "Severity levels for warnings, gaps, and validation issues.",
      "enum": [
        "info",
        "warning",
        "error",
        "critical"
      ],
      "title": "Severity",
      "type": "string"
    },
    "TelemetryContext": {
      "description": "Telemetry correlation metadata propagated across CLI, API, and services.",
      "properties": {
        "trace_id": {
          "description": "OpenTelemetry trace ID",
          "title": "Trace Id",
          "type": "string"
        },
        "span_id": {
          "description": "OpenTelemetry span ID",
          "title": "Span Id",
          "type": "string"
        },
        "correlation_id": {
          "description": "Platform correlation ID (UUID)",
          "title": "Correlation Id",
          "type": "string"
        },
        "parent_span_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Parent span ID for nested operations",
          "title": "Parent Span Id"
        }
      },
      "required": [
        "trace_id",
        "span_id",
        "correlation_id"
      ],
      "title": "TelemetryContext",
      "type": "object"
    },
    "Warning": {
      "description": "A warning emitted during analysis or transformation.",
      "properties": {
        "code": {
          "description": "Machine-readable warning code (e.g., 'MISSING_CONNECTOR_CONFIG')",
          "title": "Code",
          "type": "string"
        },
        "message": {
          "description": "Human-readable warning message",
          "title": "Message",
          "type": "string"
        },
        "severity": {
          "$ref": "#/$defs/Severity",
          "default": "warning",
          "description": "Warning severity"
        },
        "source_location": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Optional source file and line reference",
          "title": "Source Location"
        }
      },
      "required": [
        "code",
        "message"
      ],
      "title": "Warning",
      "type": "object"
    }
  },
  "description": "Response from transforming a MuleSoft project or single flow.",
  "properties": {
    "mode": {
      "$ref": "#/$defs/InputMode",
      "description": "Input mode used for transformation"
    },
    "project_name": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Project name (from pom.xml in project mode, None in single-flow mode)",
      "title": "Project Name"
    },
    "artifacts": {
      "$ref": "#/$defs/ArtifactManifest",
      "description": "Manifest of generated output artifacts"
    },
    "gaps": {
      "description": "Migration gaps encountered during transformation",
      "items": {
        "$ref": "#/$defs/MigrationGap"
      },
      "title": "Gaps",
      "type": "array"
    },
    "warnings": {
      "description": "Warnings emitted during transformation",
      "items": {
        "$ref": "#/$defs/Warning"
      },
      "title": "Warnings",
      "type": "array"
    },
    "constructs": {
      "$ref": "#/$defs/ConstructCount",
      "description": "Construct counts for the transformation"
    },
    "telemetry": {
      "$ref": "#/$defs/TelemetryContext",
      "description": "Telemetry context for trace correlation"
    }
  },
  "required": [
    "mode",
    "artifacts",
    "telemetry"
  ],
  "title": "TransformResponse",
  "type": "object"
}
