<?xml version="1.0" encoding="UTF-8"?>
<mule xmlns="http://www.mulesoft.org/schema/mule/core"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:schemaLocation="
        http://www.mulesoft.org/schema/mule/core http://www.mulesoft.org/schema/mule/core/current/mule.xsd">

    <sub-flow name="sharedLogic">
        <set-variable variableName="status" value="processed"/>
        <set-payload value="Processed by shared logic"/>
    </sub-flow>

    <sub-flow name="errorHandlingLogic">
        <set-variable variableName="errorCode" value="500"/>
        <set-payload value="Error handled"/>
    </sub-flow>

</mule>
